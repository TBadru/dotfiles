# run "ghostty +list-themes" to see themes available on your system and modify according to your preferences.
# Theme
theme = "Catppuccin Latte"

# Font
font-family = "JetBrains Mono"
font-size = 14

# Cursor
shell-integration-features = no-cursor
cursor-style = block
mouse-hide-while-typing = true

# Clipboard
copy-on-select = clipboard

# macOS
macos-titlebar-style = tabs
macos-auto-secure-input = true

# Split navigation
keybind = cmd+shift+up=goto_split:top
keybind = cmd+shift+down=goto_split:bottom
keybind = cmd+shift+left=goto_split:left
keybind = cmd+shift+right=goto_split:right

# Create splits
keybind = cmd+ctrl+shift+up=new_split:up
keybind = cmd+ctrl+shift+down=new_split:down
keybind = cmd+ctrl+shift+left=new_split:left
keybind = cmd+ctrl+shift+right=new_split:right

# Insert newline without submitting
keybind = shift+enter=text:\n
